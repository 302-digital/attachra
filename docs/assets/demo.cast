[0.082, "o", "An attachment was removed and is available for download:\r\n\r\n  - quarterly-report.pdf (658 B)\r\n\r\nDownload link: http://localhost:8080/p/ghLLFBT4QKrd3gsgc9P3Fg\r\nThis link expires on 2026-07-22 17:22 UTC.\r\nSent by: sender@attachra-dev.local\r\n\r\nThis message was processed by Attachra.\r\n\r\n--088acf213b6fa121ad4c3908cc2c8cff889ad90018d0f52bf136ea930282--\r\n\r\n"]
[3.508, "o", "\r\n# 4. Download the file from its personal link\r\n"]
