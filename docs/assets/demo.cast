[2.615, "o", "\r\n# 1. Send an email with a PDF attachment through Postfix\r\n$ go run ./hack/sendmail-test --smtp localhost:2525 \\\r\n    --from sender@attachra-dev.local --to recipient@attachra-dev.local \\\r\n"]
